{
  "name": "audiosense-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsx server.ts\" \"tsx worker.ts\"",
    "dev:api": "tsx server.ts",
    "dev:worker": "tsx worker.ts",
    "dev:local-engine": "cd python-runtime && PYTHONPATH=src python3 -m local_audio_runtime.server",
    "start": "concurrently -k \"node dist-server/server.js\" \"node dist-server/worker.js\"",
    "start:api": "node dist-server/server.js",
    "worker": "node dist-server/worker.js",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:rollback": "tsx scripts/db-rollback.ts",
    "db:status": "tsx scripts/db-status.ts",
    "db:migrate:make": "tsx scripts/db-migrate-make.ts",
    "db:migrate:sqlite-to-pg": "tsx scripts/db-migrate-sqlite-to-pg.ts",
    "db:reindex-search": "tsx scripts/db-reindex-search.ts",
    "create:user": "tsx scripts/create-user.ts",
    "list:users": "tsx scripts/list-users.ts",
    "delete:user": "tsx scripts/delete-user.ts",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts tests/unit/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "range-parser": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "spark-md5": "^3.0.2",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/spark-md5": "^3.0.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
