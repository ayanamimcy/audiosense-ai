# Core app
PORT="3000"
DB_TYPE="sqlite3"
SQLITE_FILENAME=""
UPLOAD_DIR=""
ALLOW_REGISTRATION="false"
USER_SETTINGS_ENCRYPTION_KEY=""

# Primary provider selection
TRANSCRIPTION_PROVIDER="local-python"

# OpenAI-compatible transcription provider
OPENAI_TRANSCRIPTION_API_BASE_URL="https://api.openai.com/v1"
OPENAI_TRANSCRIPTION_API_KEY=""
OPENAI_TRANSCRIPTION_PATH="/audio/transcriptions"
OPENAI_TRANSLATION_PATH="/audio/translations"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"
OPENAI_TRANSCRIPTION_RESPONSE_FORMAT="verbose_json"
OPENAI_TRANSCRIPTION_DISABLE_TIMESTAMP_GRANULARITIES="false"

# Azure OpenAI transcription provider
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2024-10-21"

# Local Python audio runtime
LOCAL_AUDIO_ENGINE_ENABLED="false"
LOCAL_AUDIO_ENGINE_AUTOSTART="true"
LOCAL_AUDIO_ENGINE_URL=""
LOCAL_AUDIO_ENGINE_HOST="127.0.0.1"
LOCAL_AUDIO_ENGINE_PORT="8765"
LOCAL_AUDIO_ENGINE_BACKEND="faster-whisper"
LOCAL_AUDIO_ENGINE_MODEL="small"
LOCAL_AUDIO_ENGINE_DEVICE="auto"
LOCAL_AUDIO_ENGINE_COMPUTE_TYPE="default"
LOCAL_AUDIO_ENGINE_BEAM_SIZE="5"
LOCAL_AUDIO_ENGINE_BATCH_SIZE="16"
LOCAL_AUDIO_ENGINE_VAD_FILTER="true"
LOCAL_AUDIO_ENGINE_DIARIZATION_MODEL="pyannote/speaker-diarization-community-1"
LOCAL_AUDIO_ENGINE_DIARIZATION_STRATEGY="auto"
LOCAL_AUDIO_ENGINE_PREFER_INTEGRATED_DIARIZATION="true"
LOCAL_AUDIO_ENGINE_SEQUENTIAL_UNLOAD_BETWEEN_STAGES="true"
LOCAL_AUDIO_ENGINE_HF_TOKEN=""
LOCAL_AUDIO_ENGINE_DOWNLOAD_ROOT=""
LOCAL_AUDIO_ENGINE_PRELOAD="false"
LOCAL_AUDIO_ENGINE_STARTUP_TIMEOUT_MS="120000"
LOCAL_AUDIO_ENGINE_REQUEST_TIMEOUT_MS="3600000"
LOCAL_AUDIO_ENGINE_TRANSLATION_TARGET_LANGUAGE="en"
LOCAL_AUDIO_ENGINE_NORMALIZE_AUDIO="false"
LOCAL_AUDIO_ENGINE_PRE_VAD_NORMALIZE="false"
LOCAL_AUDIO_ENGINE_SILERO_SENSITIVITY="0.4"
LOCAL_AUDIO_ENGINE_WEBRTC_SENSITIVITY="3"
LOCAL_AUDIO_ENGINE_SILERO_USE_ONNX="false"
LOCAL_AUDIO_ENGINE_SILERO_DEACTIVITY_DETECTION="false"
LOCAL_AUDIO_ENGINE_POST_SPEECH_SILENCE_DURATION="0.8"
LOCAL_AUDIO_ENGINE_MIN_LENGTH_OF_RECORDING="0.4"
LOCAL_AUDIO_ENGINE_MIN_GAP_BETWEEN_RECORDINGS="0.2"
LOCAL_AUDIO_ENGINE_PRE_RECORDING_BUFFER_DURATION="1.0"
LOCAL_AUDIO_ENGINE_MAX_SILENCE_DURATION="10.0"
LOCAL_AUDIO_ENGINE_ALLOWED_LATENCY_LIMIT="100"
LOCAL_AUDIO_ENGINE_ENSURE_SENTENCE_STARTING_UPPERCASE="true"
LOCAL_AUDIO_ENGINE_ENSURE_SENTENCE_ENDS_WITH_PERIOD="true"
LOCAL_AUDIO_ENGINE_BUFFER_SIZE="512"

# LLM for summaries and chat
LLM_API_BASE_URL="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
AUTO_GENERATE_SUMMARY="false"

# Embeddings for vector retrieval / hybrid search
EMBEDDING_API_BASE_URL="https://api.openai.com/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"

# Worker tuning
WORKER_IDLE_MS="3000"
