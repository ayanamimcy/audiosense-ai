{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist-server",
    "rootDir": "."
  },
  "include": [
    "server.ts",
    "worker.ts",
    "db.ts",
    "lib/**/*.ts",
    "database/**/*.ts",
    "routes/**/*.ts",
    "application/**/*.ts"
  ],
  "exclude": [
    "src/**",
    "tests/**",
    "scripts/**",
    "node_modules/**"
  ]
}
